{
  "name": "trade-xyz",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:convex": "CONVEX_NO_UPDATE_CHECK=true bun x convex dev --env-file .env.local --local",
    "dev:ui": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:convex": "bash -lc \"export CONVEX_DEPLOYMENT=$(grep -m1 '^CONVEX_DEPLOYMENT=' .env.local | cut -d= -f2- | sed -E 's/[[:space:]]+#.*$//'); CONVEX_NO_UPDATE_CHECK=true bun x convex deploy\""
  },
  "dependencies": {
    "convex": "^1.31.7",
    "lightweight-charts": "^5.1.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^7.0.2",
    "vite": "^6.4.1",
    "vite-plugin-solid": "^2.11.10"
  }
}
